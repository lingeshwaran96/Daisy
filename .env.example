# =============================================
# DAISY - Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================

# Supabase Configuration (get from https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Razorpay (get from https://razorpay.com)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# WhatsApp Business Number (include country code, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# Admin credentials (used only for initial setup reference)
ADMIN_EMAIL=admin@daisy.com
ADMIN_PASSWORD=Daisy@123

# Site URL (change to your domain for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Email notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
